Bridge mqtt:broker:mosquitto "Mosquitto" [ host="127.0.0.1", port=1883, secure=false, clientID="openHAB2" ]
{
Thing topic pool-controller "Smart Pool Controller" @ "Garten" {
			Channels:
				//OperationMode
				Type string : operationMode 	"Modus"							[ stateTopic="pool-controller/select/operation-mode/state", commandTopic="pool-controller/select/operation-mode/command"]
				//configs
				Type number : maxPoolTemp 		"max. Pool Temp"		[ stateTopic="pool-controller/number/pool-max-temp/state", commandTopic="pool-controller/number/pool-max-temp/command"]
				Type number : minSolarTemp 		"min. Solar Temp"		[ stateTopic="pool-controller/number/solar-min-temp/state", commandTopic="pool-controller/number/solar-min-temp/command"]
				Type number : hysteresis	 		"Hysterese"					[ stateTopic="pool-controller/number/hysteresis/state", commandTopic="pool-controller/number/hysteresis/command"]

				Type number : timerStartH	 		"Timer start H"			[ stateTopic="pool-controller/number/timer-start-h/state", commandTopic="pool-controller/number/timer-start-h/command"]
				Type number : timerStartM	 		"Timer start Min"		[ stateTopic="pool-controller/number/timer-start-min/state", commandTopic="pool-controller/number/timer-start-min/command"]
				Type number : timerEndH	 			"Timer end H"				[ stateTopic="pool-controller/number/timer-end-h/state", commandTopic="pool-controller/number/timer-end-h/command"]
				Type number : timerEndM	 			"Timer end Min"			[ stateTopic="pool-controller/number/timer-end-min/state", commandTopic="pool-controller/number/timer-end-min/command"]

				//Solar Pump
				Type switch : solarPumpSwitch	"Solar Pumpe" 			[ stateTopic="pool-controller/switch/solar-pump/state", commandTopic="pool-controller/switch/solar-pump/command", on="ON", off="OFF" ]
				Type switch : poolPumpSwitch	"pool Pumpe" 				[ stateTopic="pool-controller/switch/pool-pump/state", commandTopic="pool-controller/switch/pool-pump/command", on="ON", off="OFF" ]

				Type number : solarTemp 			"Solar Temperatur" 	[ stateTopic="pool-controller/sensor/solar-temp/state"]
				Type number : poolTemp 				"Pool Temperatur" 	[ stateTopic="pool-controller/sensor/pool-temp/state"]


				//Device properties (HA MQTT sensor entities)
				Type number : controllerSignal "Signal"						[ stateTopic="pool-controller/sensor/signal/state"]
				Type number : controllerUptime "Uptime"						[ stateTopic="pool-controller/sensor/uptime/state"]

				Type string : controllerOnline "Online"						[ stateTopic="pool-controller/status"]

				Type string : fwName 		"FW Name"									[ stateTopic="pool-controller/sensor/fw-name/state"]
				Type string : fwVersion "FW Version"							[ stateTopic="pool-controller/sensor/fw-version/state"]
		}
}
